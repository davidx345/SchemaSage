# Development Environment Variables
# WARNING: These are weak passwords for development only!

# Main Database
POSTGRES_DB=schemasage_db
POSTGRES_USER=schemasage
POSTGRES_PASSWORD=dev_password_123

# Schema Detection Database
SCHEMA_DB_NAME=schema_detection
SCHEMA_DB_USER=schema_user
SCHEMA_DB_PASSWORD=dev_schema_123

# Project Management Database
PROJECT_DB_NAME=project_management
PROJECT_DB_USER=project_user
PROJECT_DB_PASSWORD=dev_project_123

# Authentication Database
AUTH_DB_NAME=authentication
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=dev_auth_123

# RabbitMQ
RABBITMQ_DEFAULT_USER=schemasage
RABBITMQ_DEFAULT_PASS=dev_rabbit_123

# JWT Secrets
JWT_SECRET_KEY=dev_jwt_secret_key_not_for_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys (Set these for development)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Security Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
MAX_FILE_SIZE=10485760  # 10MB
RATE_LIMIT_PER_MINUTE=100
