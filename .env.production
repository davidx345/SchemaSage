# Production Environment Variables
# CRITICAL: Generate strong passwords before deployment

# Main Database
POSTGRES_DB=schemasage_db
POSTGRES_USER=schemasage
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_2024!

# Schema Detection Database
SCHEMA_DB_NAME=schema_detection
SCHEMA_DB_USER=schema_user
SCHEMA_DB_PASSWORD=CHANGE_ME_SCHEMA_PWD_2024!

# Project Management Database
PROJECT_DB_NAME=project_management
PROJECT_DB_USER=project_user
PROJECT_DB_PASSWORD=CHANGE_ME_PROJECT_PWD_2024!

# Authentication Database
AUTH_DB_NAME=authentication
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=CHANGE_ME_AUTH_PWD_2024!

# RabbitMQ
RABBITMQ_DEFAULT_USER=schemasage
RABBITMQ_DEFAULT_PASS=CHANGE_ME_RABBIT_PWD_2024!

# JWT Secrets
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_256_BIT_KEY_2024!
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# API Keys (Set these in production)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Security Settings
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
MAX_FILE_SIZE=10485760  # 10MB
RATE_LIMIT_PER_MINUTE=60
