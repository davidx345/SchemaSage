{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "{{ title if title else 'Generated Schema' }}",
  "description": "{{ description if description else 'Schema generated by SchemaSage on ' + now().strftime('%Y-%m-%d %H:%M:%S') }}",
  "type": "object",
  "definitions": {
    {% for table in tables %}
    "{{ table.name }}": {
      "type": "object",
      {% if table.description %}"description": "{{ table.description }}",{% endif %}
      "properties": {
        {% for column in table.columns %}
        "{{ column.name }}": {
          "type": "{{ column.json_type }}",
          {% if column.description %}"description": "{{ column.description }}",{% endif %}
          {% if column.format %}"format": "{{ column.format }}",{% endif %}
          {% if column.enum %}"enum": {{ column.enum|tojson }},{% endif %}
          {% if column.pattern %}"pattern": "{{ column.pattern }}",{% endif %}
          {% if column.minimum is not none %}"minimum": {{ column.minimum }},{% endif %}
          {% if column.maximum is not none %}"maximum": {{ column.maximum }},{% endif %}
          {% if column.minLength is not none %}"minLength": {{ column.minLength }},{% endif %}
          {% if column.maxLength is not none %}"maxLength": {{ column.maxLength }},{% endif %}
          {% if column.validation %}
          {% if column.validation == 'email' %}
          "format": "email",
          "pattern": "^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$"
          {% elif column.validation == 'url' %}
          "format": "uri",
          "pattern": "^https?://[^\\s/$.?#].[^\\s]*$"
          {% elif column.validation == 'phone' %}
          "pattern": "^\\+?1?\\d{9,15}$"
          {% endif %}
          {% endif %}
          {% if column.statistics %}
          {% if column.statistics.examples %}
          "examples": {{ column.statistics.examples|tojson }},
          {% endif %}
          {% endif %}
          {% if column.default is not none %}
          "default": {{ column.default|tojson }},
          {% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      },
      "required": [
        {% for column in table.columns if not column.nullable %}
        "{{ column.name }}"{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      {% if table.indexes %}
      "indexes": [
        {% for index in table.indexes %}
        {
          "name": "{{ index.name }}",
          "columns": {{ index.columns|tojson }}
          {% if index.unique %}, "unique": true{% endif %}
        }{% if not loop.last %},{% endif %}
        {% endfor %}
      ],
      {% endif %}
      {% if relationships[table.name] %}
      "relationships": {
        {% if relationships[table.name]['outgoing'] %}
        "outgoing": [
          {% for rel in relationships[table.name]['outgoing'] %}
          {
            "name": "{{ rel.name }}",
            "target": "{{ rel.target_table }}",
            "type": "{{ rel.type }}",
            {% if rel.metadata and rel.metadata.description %}
            "description": "{{ rel.metadata.description }}",
            {% endif %}
            "backref": "{{ rel.backref_name }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ],
        {% endif %}
        {% if relationships[table.name]['incoming'] %}
        "incoming": [
          {% for rel in relationships[table.name]['incoming'] %}
          {
            "name": "{{ rel.name }}",
            "source": "{{ rel.source_table }}",
            "type": "{{ rel.type }}",
            {% if rel.metadata and rel.metadata.description %}
            "description": "{{ rel.metadata.description }}",
            {% endif %}
            "backref": "{{ rel.backref_name }}"
          }{% if not loop.last %},{% endif %}
          {% endfor %}
        ]
        {% endif %}
      },
      {% endif %}
      "additionalProperties": {% if strict_mode %}false{% else %}true{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  },
  {% if metadata and metadata.bridge_tables %}
  "bridgeTables": [
    {% for bridge in metadata.bridge_tables %}
    {
      "name": "{{ bridge.name }}",
      "sourceTable": "{{ bridge.source_table }}",
      "targetTable": "{{ bridge.target_table }}",
      {% if bridge.description %}"description": "{{ bridge.description }}",{% endif %}
      "columns": {
        "{{ bridge.source_column }}": {
          "type": "integer",
          "foreignKey": "{{ bridge.source_table }}.id"
        },
        "{{ bridge.target_column }}": {
          "type": "integer",
          "foreignKey": "{{ bridge.target_table }}.id"
        }
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ],
  {% endif %}
  "metadata": {
    "generatedAt": "{{ now().strftime('%Y-%m-%d %H:%M:%S') }}",
    "version": "{{ version if version else '1.0.0' }}",
    "tableCount": {{ tables|length }},
    "relationshipCount": {{ relationships|sum(attribute='length') }},
    {% if metadata %}
    {% if metadata.database %}
    "database": {{ metadata.database|tojson }},
    {% endif %}
    {% if metadata.schema %}
    "schema": {{ metadata.schema|tojson }},
    {% endif %}
    {% if metadata.description %}
    "description": "{{ metadata.description }}",
    {% endif %}
    {% endif %}
    "strictMode": {{ 'true' if strict_mode else 'false' }}
  }
}