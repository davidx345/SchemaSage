-- Generated by SchemaSage
-- Generation Date: {{ now().strftime('%Y-%m-%d %H:%M:%S') }}
{% if create_schema %}
-- Create Schema
CREATE SCHEMA IF NOT EXISTS {{ schema_name }};
SET search_path TO {{ schema_name }};
{% endif %}

{% for table in tables %}
-- Table: {{ table.name }}
{% if table.description %}
{% if add_comments %}
COMMENT ON TABLE {{ table.name }} IS '{{ table.description }}';
{% else %}
-- Description: {{ table.description }}
{% endif %}
{% endif %}

CREATE TABLE {{ table.name }} (
    {% for column in table.columns %}
    {{ column.name }} {{ column.type }}
    {%- if column.is_primary_key %} PRIMARY KEY{% endif %}
    {%- if not column.nullable %} NOT NULL{% endif %}
    {%- if column.default %} DEFAULT {{ column.default }}{% endif %}
    {%- if column.check %} {{ column.check }}{% endif %}
    {%- if column.unique %} UNIQUE{% endif %}
    {%- if not loop.last %},{% endif %}
    {% if column.comment and add_comments %}
    -- Add column comment
    COMMENT ON COLUMN {{ table.name }}.{{ column.name }} IS '{{ column.comment }}';
    {% endif %}
    {% if column.statistics %}
    -- Stats: {{ column.statistics.unique_count }} unique values ({{ "%.1f"|format(column.statistics.unique_percentage) }}% unique)
    {% if column.statistics.null_count is not none %}
    -- {{ column.statistics.null_count }} null values ({{ "%.1f"|format(column.statistics.null_percentage) }}%)
    {% endif %}
    {% endif %}

    {% endfor %}
);

{% if table.indexes %}
-- Indexes for {{ table.name }}
{% for index in table.indexes %}
{{ index }};
{% endfor %}
{% endif %}

{% endfor %}

-- Foreign Key Constraints
{% for rel in relationships %}
ALTER TABLE {{ rel.source_table }}
    ADD CONSTRAINT fk_{{ rel.source_table }}_{{ rel.target_table }}_{{ rel.source_column }}
    FOREIGN KEY ({{ rel.source_column }})
    REFERENCES {{ rel.target_table }}({{ rel.target_column }})
    {% if rel.on_delete %}ON DELETE {{ rel.on_delete }}{% else %}ON DELETE SET NULL{% endif %}
    {% if rel.on_update %}ON UPDATE {{ rel.on_update }}{% else %}ON UPDATE CASCADE{% endif %};
{% if rel.metadata and rel.metadata.description and add_comments %}
COMMENT ON CONSTRAINT fk_{{ rel.source_table }}_{{ rel.target_table }}_{{ rel.source_column }} 
    ON {{ rel.source_table }} IS '{{ rel.metadata.description }}';
{% endif %}
{% endfor %}

{% if metadata and metadata.bridge_tables %}
-- Bridge Tables for Many-to-Many Relationships
{% for bridge in metadata.bridge_tables %}
CREATE TABLE {{ bridge.name }} (
    id SERIAL PRIMARY KEY,
    {{ bridge.source_column }} INTEGER NOT NULL REFERENCES {{ bridge.source_table }}(id),
    {{ bridge.target_column }} INTEGER NOT NULL REFERENCES {{ bridge.target_table }}(id),
    {% if bridge.metadata and bridge.metadata.add_timestamps %}
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    {% endif %}
    CONSTRAINT uix_{{ bridge.name }} UNIQUE({{ bridge.source_column }}, {{ bridge.target_column }})
);

{% if bridge.description and add_comments %}
COMMENT ON TABLE {{ bridge.name }} IS '{{ bridge.description }}';
{% endif %}

CREATE INDEX ix_{{ bridge.name }}_{{ bridge.source_column }} ON {{ bridge.name }}({{ bridge.source_column }});
CREATE INDEX ix_{{ bridge.name }}_{{ bridge.target_column }} ON {{ bridge.name }}({{ bridge.target_column }});
{% endfor %}
{% endif %}

-- Validation Triggers
{% for table in tables %}
{% for column in table.columns if column.validation %}
CREATE OR REPLACE FUNCTION validate_{{ table.name }}_{{ column.name }}()
RETURNS TRIGGER AS $$
BEGIN
    {% if column.validation == 'email' %}
    IF NEW.{{ column.name }} IS NOT NULL AND NEW.{{ column.name }} !~ '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}$' THEN
        RAISE EXCEPTION 'Invalid email format in column {{ column.name }}';
    END IF;
    {% elif column.validation == 'url' %}
    IF NEW.{{ column.name }} IS NOT NULL AND NEW.{{ column.name }} !~ '^https?://[^\s/$.?#].[^\s]*$' THEN
        RAISE EXCEPTION 'Invalid URL format in column {{ column.name }}';
    END IF;
    {% elif column.validation == 'phone' %}
    IF NEW.{{ column.name }} IS NOT NULL AND NEW.{{ column.name }} !~ '^\+?1?\d{9,15}$' THEN
        RAISE EXCEPTION 'Invalid phone number format in column {{ column.name }}';
    END IF;
    {% endif %}
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER validate_{{ table.name }}_{{ column.name }}_trigger
    BEFORE INSERT OR UPDATE ON {{ table.name }}
    FOR EACH ROW
    EXECUTE FUNCTION validate_{{ table.name }}_{{ column.name }}();
{% endfor %}
{% endfor %}

-- Statistics and Metadata
{% if add_comments %}
COMMENT ON DATABASE {{ metadata.database_name if metadata.database_name else 'current_database' }} IS '
Database Statistics:
- Total Tables: {{ tables|length }}
- Total Relations: {{ relationships|length }}
- Bridge Tables: {{ metadata.bridge_tables|length if metadata and metadata.bridge_tables else 0 }}
- Generated: {{ now().strftime("%Y-%m-%d %H:%M:%S") }}
{% if metadata and metadata.description %}
{{ metadata.description }}
{% endif %}
';
{% endif %}